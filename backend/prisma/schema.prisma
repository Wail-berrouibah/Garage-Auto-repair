generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// ENUMS
// ============================================================

enum WoStatus {
  OPEN
  DIAGNOSED
  WAITING_PARTS
  IN_PROGRESS
  QUALITY_CHECK
  COMPLETED
  DELIVERED
}

enum PoStatus {
  DRAFT
  SENT
  CONFIRMED
  SHIPPED
  PARTIAL
  RECEIVED
  CANCELLED
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  PARTIALLY_PAID
  PAID
  CANCELLED
  CREDITED
}

enum PaymentMethod {
  CASH
  CARD
  BANK_TRANSFER
  CHECK
}

enum TransferStatus {
  DRAFT
  PENDING
  IN_TRANSIT
  RECEIVED
  CANCELLED
}

enum MovementType {
  RECEIVING
  SALE
  ADJUSTMENT
  TRANSFER_OUT
  TRANSFER_IN
  RETURN_TO_SUPPLIER
  RETURN_FROM_CUSTOMER
}

enum NoteType {
  INTERNAL
  CUSTOMER
  TECHNICAL
}

enum Priority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum CustomerType {
  INDIVIDUAL
  COMPANY
}

enum RoleName {
  OWNER
  MANAGER
  RECEPTIONIST
  MECHANIC
  ACCOUNTANT
  INVENTORY_MANAGER
}

// ============================================================
// MODELS
// ============================================================

model Branch {
  id          String   @id @default(uuid()) @db.Uuid
  code        String   @unique @db.VarChar(10)
  name        String   @db.VarChar(255)
  addressLine1 String  @map("address_line1") @db.VarChar(255)
  addressLine2 String? @map("address_line2") @db.VarChar(255)
  city        String   @db.VarChar(100)
  state       String   @db.VarChar(100)
  zipCode     String   @map("zip_code") @db.VarChar(20)
  country     String   @default("US") @db.VarChar(100)
  phone       String?  @db.VarChar(30)
  email       String?  @db.VarChar(255)
  taxId       String?  @map("tax_id") @db.VarChar(50)
  currency    String   @default("USD") @db.VarChar(3)
  timezone    String   @default("America/New_York") @db.VarChar(50)
  settings    Json     @default("{}")
  isActive    Boolean  @default(true) @map("is_active")
  deletedAt   DateTime? @map("deleted_at")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  users            UserBranchAssignment[]
  customers        Customer[]
  vehicles         Vehicle[]
  workOrders       WorkOrder[]
  services         Service[]
  warehouses       Warehouse[]
  suppliers        Supplier[]
  purchaseOrders   PurchaseOrder[]
  invoices         Invoice[]
  payments         Payment[]
  qcResults        QcInspectionResult[]
  checklistTemplates ChecklistTemplate[]
  userRoles        UserRole[]
  documents        Document[]
  auditEntries     AuditEntry[]
  transferOrdersFrom TransferOrder[] @relation("FromBranch")
  transferOrdersTo   TransferOrder[] @relation("ToBranch")

  @@map("branches")
}

model User {
  id              String   @id @default(uuid()) @db.Uuid
  email           String   @unique @db.VarChar(255)
  passwordHash    String   @map("password_hash") @db.VarChar(255)
  firstName       String   @map("first_name") @db.VarChar(100)
  lastName        String   @map("last_name") @db.VarChar(100)
  phone           String?  @db.VarChar(30)
  isActive        Boolean  @default(true) @map("is_active")
  isLocked        Boolean  @default(false) @map("is_locked")
  failedAttempts  Int      @default(0) @map("failed_attempts")
  lastLoginAt     DateTime? @map("last_login_at")
  passwordChangedAt DateTime @default(now()) @map("password_changed_at")
  refreshToken    String?  @map("refresh_token")
  preferences     Json     @default("{\"theme\":\"light\",\"locale\":\"en\",\"timezone\":\"UTC\"}")
  deletedAt       DateTime? @map("deleted_at")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  roles            UserRole[]
  branchAssignments UserBranchAssignment[]
  workOrdersAssigned WorkOrder[] @relation("AssignedMechanic")
  laborEntries     LaborEntry[]
  timeEntries      TimeEntry[]
  workNotes        WorkNote[]
  woAttachments    WoAttachment[]
  stockMovements   StockMovement[]
  purchaseOrders   PurchaseOrder[] @relation("POCreator")
  approvedPOs      PurchaseOrder[] @relation("POApprover")
  creditNotes      CreditNote[]
  payments         Payment[] @relation("PaymentReceiver")
  qcInspections    QcInspectionResult[]
  documents        Document[]
  auditEntries     AuditEntry[]
  sentTransfers    TransferOrder[] @relation("TransferRequester")
  approvedTransfers TransferOrder[] @relation("TransferApprover")
  notifications     Notification[]

  @@map("users")
}

model UserRole {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  roleId    String   @map("role_id") @db.Uuid
  branchId  String?  @map("branch_id") @db.Uuid
  grantedAt DateTime @default(now()) @map("granted_at")
  grantedBy String?  @map("granted_by") @db.Uuid

  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  role    Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)
  branch  Branch? @relation(fields: [branchId], references: [id], onDelete: SetNull)

  @@unique([userId, roleId, branchId])
  @@map("user_roles")
}

model Role {
  id          String   @id @default(uuid()) @db.Uuid
  name        RoleName @unique
  description String?  @db.VarChar(255)
  isSystem    Boolean  @default(false) @map("is_system")
  createdAt   DateTime @default(now()) @map("created_at")

  users       UserRole[]
  permissions Permission[]

  @@map("roles")
}

model Permission {
  id       String           @id @default(uuid()) @db.Uuid
  roleId   String           @map("role_id") @db.Uuid
  resource String           @db.VarChar(100)
  action   String           @db.VarChar(50)
  scope    String           @default("BRANCH") @db.VarChar(20)

  role     Role             @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, resource, action])
  @@map("permissions")
}

model UserBranchAssignment {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  branchId  String   @map("branch_id") @db.Uuid
  isPrimary Boolean  @default(false) @map("is_primary")
  assignedAt DateTime @default(now()) @map("assigned_at")

  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  branch  Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@unique([userId, branchId])
  @@map("user_branch_assignments")
}

model Customer {
  id            String       @id @default(uuid()) @db.Uuid
  branchId      String       @map("branch_id") @db.Uuid
  customerType  CustomerType @default(INDIVIDUAL) @map("customer_type")
  firstName     String       @map("first_name") @db.VarChar(100)
  lastName      String       @map("last_name") @db.VarChar(100)
  companyName   String?      @map("company_name") @db.VarChar(255)
  email         String?      @db.VarChar(255)
  phone         String?      @db.VarChar(30)
  phoneSecondary String?     @map("phone_secondary") @db.VarChar(30)
  addressLine1  String?      @map("address_line1") @db.VarChar(255)
  addressLine2  String?      @map("address_line2") @db.VarChar(255)
  city          String?      @db.VarChar(100)
  state         String?      @db.VarChar(100)
  zipCode       String?      @map("zip_code") @db.VarChar(20)
  taxId         String?      @map("tax_id") @db.VarChar(50)
  notes         String?      @db.Text
  tags          String[]
  isActive      Boolean      @default(true) @map("is_active")
  deletedAt     DateTime?    @map("deleted_at")
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")

  branch         Branch         @relation(fields: [branchId], references: [id])
  vehicles       CustomerVehicle[]
  workOrders     WorkOrder[]
  invoices       Invoice[]

  @@index([branchId])
  @@index([email])
  @@index([phone])
  @@index([lastName, firstName])
  @@map("customers")
}

model CustomerVehicle {
  id           String   @id @default(uuid()) @db.Uuid
  customerId   String   @map("customer_id") @db.Uuid
  vehicleId    String   @map("vehicle_id") @db.Uuid
  isPrimary    Boolean  @default(false) @map("is_primary")
  relationship String   @default("OWNER") @db.VarChar(50)
  assignedAt   DateTime @default(now()) @map("assigned_at")

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  vehicle  Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@unique([customerId, vehicleId])
  @@map("customer_vehicles")
}

model Vehicle {
  id              String   @id @default(uuid()) @db.Uuid
  branchId        String   @map("branch_id") @db.Uuid
  vin             String   @unique @db.VarChar(17)
  licensePlate    String?  @map("license_plate") @db.VarChar(20)
  licenseState    String?  @map("license_state") @db.VarChar(50)
  make            String?  @db.VarChar(100)
  model           String?  @db.VarChar(100)
  year            Int?     @db.SmallInt
  trimLevel       String?  @map("trim_level") @db.VarChar(100)
  engine          String?  @db.VarChar(100)
  transmission    String?  @db.VarChar(50)
  drivetrain      String?  @db.VarChar(50)
  fuelType        String?  @map("fuel_type") @db.VarChar(50)
  color           String?  @db.VarChar(50)
  bodyClass       String?  @map("body_class") @db.VarChar(100)
  manufactureYear Int?     @map("manufacture_year") @db.SmallInt
  odometer        Int?
  odometerUnit    String   @default("mi") @map("odometer_unit") @db.VarChar(5)
  notes           String?  @db.Text
  deletedAt       DateTime? @map("deleted_at")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  branch    Branch            @relation(fields: [branchId], references: [id])
  customers CustomerVehicle[]
  workOrders WorkOrder[]

  @@index([branchId])
  @@index([vin])
  @@index([licensePlate])
  @@index([make, model])
  @@map("vehicles")
}

model Service {
  id             String   @id @default(uuid()) @db.Uuid
  branchId       String   @map("branch_id") @db.Uuid
  code           String   @db.VarChar(50)
  name           String   @db.VarChar(255)
  description    String?  @db.Text
  category       String?  @db.VarChar(100)
  defaultRate    Decimal  @default(0) @map("default_rate") @db.Decimal(10, 2)
  rateUnit       String   @default("HOURLY") @map("rate_unit") @db.VarChar(10)
  estimatedHours Decimal? @map("estimated_hours") @db.Decimal(5, 2)
  isActive       Boolean  @default(true) @map("is_active")
  deletedAt      DateTime? @map("deleted_at")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  branch       Branch        @relation(fields: [branchId], references: [id])
  laborEntries LaborEntry[]

  @@unique([code, branchId])
  @@index([branchId])
  @@map("services")
}

model WorkOrder {
  id             String   @id @default(uuid()) @db.Uuid
  branchId       String   @map("branch_id") @db.Uuid
  woNumber       String   @unique @map("wo_number") @db.VarChar(20)
  customerId     String   @map("customer_id") @db.Uuid
  vehicleId      String   @map("vehicle_id") @db.Uuid
  status         WoStatus @default(OPEN)
  priority       Priority @default(NORMAL)
  complaint      String   @db.Text
  diagnosis      String?  @db.Text
  odometerIn     Int?     @map("odometer_in")
  odometerOut    Int?     @map("odometer_out")
  assignedTo     String?  @map("assigned_to") @db.Uuid
  estimatedTotal Decimal? @map("estimated_total") @db.Decimal(12, 2)
  actualTotal    Decimal? @map("actual_total") @db.Decimal(12, 2)
  promisedDate   DateTime? @map("promised_date")
  startedAt      DateTime? @map("started_at")
  completedAt    DateTime? @map("completed_at")
  deliveredAt    DateTime? @map("delivered_at")
  isBlocked      Boolean  @default(false) @map("is_blocked")
  blockReason    String?  @map("block_reason") @db.VarChar(255)
  deletedAt      DateTime? @map("deleted_at")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  branch          Branch            @relation(fields: [branchId], references: [id])
  customer        Customer          @relation(fields: [customerId], references: [id])
  vehicle         Vehicle           @relation(fields: [vehicleId], references: [id])
  assignedMechanic User?            @relation("AssignedMechanic", fields: [assignedTo], references: [id])
  laborEntries    LaborEntry[]
  partEntries     PartEntry[]
  timeEntries     TimeEntry[]
  workNotes       WorkNote[]
  woAttachments   WoAttachment[]
  statusHistory   WoStatusHistory[]
  invoices        Invoice[]
  qcResults       QcInspectionResult[]

  @@index([branchId])
  @@index([status])
  @@index([customerId])
  @@index([vehicleId])
  @@index([assignedTo])
  @@index([createdAt])
  @@index([branchId, status])
  @@map("work_orders")
}

model LaborEntry {
  id             String   @id @default(uuid()) @db.Uuid
  workOrderId    String   @map("work_order_id") @db.Uuid
  serviceId      String   @map("service_id") @db.Uuid
  mechanicId     String   @map("mechanic_id") @db.Uuid
  description    String?  @db.VarChar(500)
  estimatedHours Decimal  @default(0) @map("estimated_hours") @db.Decimal(5, 2)
  actualHours    Decimal  @default(0) @map("actual_hours") @db.Decimal(5, 2)
  rate           Decimal  @db.Decimal(10, 2)
  rateUnit       String   @default("HOURLY") @map("rate_unit") @db.VarChar(10)
  lineTotal      Decimal  @default(0) @map("line_total") @db.Decimal(12, 2)
  sortOrder      Int      @default(0) @map("sort_order")
  deletedAt      DateTime? @map("deleted_at")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  workOrder WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  service   Service   @relation(fields: [serviceId], references: [id])
  mechanic  User      @relation(fields: [mechanicId], references: [id])

  @@index([workOrderId])
  @@index([mechanicId])
  @@map("labor_entries")
}

model PartEntry {
  id           String   @id @default(uuid()) @db.Uuid
  workOrderId  String   @map("work_order_id") @db.Uuid
  stockItemId  String?  @map("stock_item_id") @db.Uuid
  partNumber   String   @map("part_number") @db.VarChar(100)
  partName     String   @map("part_name") @db.VarChar(255)
  quantity     Decimal  @default(1) @db.Decimal(10, 3)
  unitPrice    Decimal  @default(0) @map("unit_price") @db.Decimal(10, 2)
  lineTotal    Decimal  @default(0) @map("line_total") @db.Decimal(12, 2)
  isBackorder  Boolean  @default(false) @map("is_backorder")
  batchNumber  String?  @map("batch_number") @db.VarChar(100)
  serialNumber String?  @map("serial_number") @db.VarChar(100)
  sortOrder    Int      @default(0) @map("sort_order")
  deletedAt    DateTime? @map("deleted_at")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  workOrder WorkOrder  @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  stockItem StockItem? @relation(fields: [stockItemId], references: [id])

  @@index([workOrderId])
  @@index([stockItemId])
  @@map("part_entries")
}

model TimeEntry {
  id           String   @id @default(uuid()) @db.Uuid
  workOrderId  String   @map("work_order_id") @db.Uuid
  mechanicId   String   @map("mechanic_id") @db.Uuid
  clockIn      DateTime @map("clock_in")
  clockOut     DateTime? @map("clock_out")
  totalMinutes Int?     @map("total_minutes")
  isBillable   Boolean  @default(true) @map("is_billable")
  notes        String?  @db.Text
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  workOrder WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  mechanic  User      @relation(fields: [mechanicId], references: [id])

  @@index([workOrderId])
  @@index([mechanicId])
  @@index([clockIn, clockOut])
  @@map("time_entries")
}

model WorkNote {
  id          String   @id @default(uuid()) @db.Uuid
  workOrderId String   @map("work_order_id") @db.Uuid
  authorId    String   @map("author_id") @db.Uuid
  noteType    NoteType @default(INTERNAL) @map("note_type")
  content     String   @db.Text
  isPinned    Boolean  @default(false) @map("is_pinned")
  deletedAt   DateTime? @map("deleted_at")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  workOrder WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  author    User      @relation(fields: [authorId], references: [id])

  @@index([workOrderId])
  @@map("work_notes")
}

model WoStatusHistory {
  id          String   @id @default(uuid()) @db.Uuid
  workOrderId String   @map("work_order_id") @db.Uuid
  fromStatus  String?  @map("from_status") @db.VarChar(20)
  toStatus    String   @map("to_status") @db.VarChar(20)
  changedBy   String   @map("changed_by") @db.Uuid
  reason      String?  @db.VarChar(500)
  createdAt   DateTime @default(now()) @map("created_at")

  workOrder WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)

  @@index([workOrderId])
  @@index([createdAt])
  @@map("wo_status_history")
}

model WoAttachment {
  id          String   @id @default(uuid()) @db.Uuid
  workOrderId String   @map("work_order_id") @db.Uuid
  documentId  String?  @map("document_id") @db.Uuid
  fileName    String   @map("file_name") @db.VarChar(255)
  fileType    String?  @map("file_type") @db.VarChar(100)
  fileSize    Int?     @map("file_size")
  s3Key       String   @map("s3_key") @db.VarChar(500)
  category    String   @default("GENERAL") @db.VarChar(50)
  uploadedBy  String   @map("uploaded_by") @db.Uuid
  deletedAt   DateTime? @map("deleted_at")
  createdAt   DateTime @default(now()) @map("created_at")

  workOrder WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  uploader  User      @relation(fields: [uploadedBy], references: [id])

  @@index([workOrderId])
  @@map("wo_attachments")
}

model Warehouse {
  id          String   @id @default(uuid()) @db.Uuid
  branchId    String   @map("branch_id") @db.Uuid
  name        String   @db.VarChar(255)
  code        String   @db.VarChar(20)
  addressLine1 String? @map("address_line1") @db.VarChar(255)
  addressLine2 String? @map("address_line2") @db.VarChar(255)
  isActive    Boolean  @default(true) @map("is_active")
  deletedAt   DateTime? @map("deleted_at")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  branch     Branch     @relation(fields: [branchId], references: [id])
  stockItems StockItem[]

  @@unique([code, branchId])
  @@index([branchId])
  @@map("warehouses")
}

model StockItem {
  id              String   @id @default(uuid()) @db.Uuid
  warehouseId     String   @map("warehouse_id") @db.Uuid
  sku             String   @db.VarChar(100)
  partNumber      String?  @map("part_number") @db.VarChar(100)
  barcode         String?  @db.VarChar(100)
  name            String   @db.VarChar(255)
  description     String?  @db.Text
  category        String?  @db.VarChar(100)
  brand           String?  @db.VarChar(100)
  unitOfMeasure   String   @default("EA") @map("unit_of_measure") @db.VarChar(20)
  quantityOnHand  Decimal  @default(0) @map("quantity_on_hand") @db.Decimal(10, 3)
  quantityReserved Decimal @default(0) @map("quantity_reserved") @db.Decimal(10, 3)
  unitCost        Decimal  @default(0) @map("unit_cost") @db.Decimal(10, 2)
  sellingPrice    Decimal  @default(0) @map("selling_price") @db.Decimal(10, 2)
  reorderPoint    Decimal  @default(0) @map("reorder_point") @db.Decimal(10, 3)
  reorderQuantity Decimal  @default(0) @map("reorder_quantity") @db.Decimal(10, 3)
  leadTimeDays    Int?     @default(0) @map("lead_time_days")
  isActive        Boolean  @default(true) @map("is_active")
  trackBatch      Boolean  @default(false) @map("track_batch")
  trackSerial     Boolean  @default(false) @map("track_serial")
  deletedAt       DateTime? @map("deleted_at")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  warehouse      Warehouse       @relation(fields: [warehouseId], references: [id])
  batches        StockBatch[]
  movements      StockMovement[]
  partEntries    PartEntry[]
  poLineItems    PoLineItem[]
  transferItems  TransferOrderItem[]

  @@unique([sku, warehouseId])
  @@index([warehouseId])
  @@index([sku])
  @@index([category])
  @@index([barcode])
  @@map("stock_items")
}

model StockBatch {
  id           String   @id @default(uuid()) @db.Uuid
  stockItemId  String   @map("stock_item_id") @db.Uuid
  batchNumber  String   @map("batch_number") @db.VarChar(100)
  serialNumber String?  @map("serial_number") @db.VarChar(100)
  quantity     Decimal  @default(0) @db.Decimal(10, 3)
  unitCost     Decimal? @map("unit_cost") @db.Decimal(10, 2)
  expiryDate   DateTime? @map("expiry_date")
  receivedDate DateTime @default(now()) @map("received_date")
  notes        String?  @db.Text
  deletedAt    DateTime? @map("deleted_at")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  stockItem StockItem       @relation(fields: [stockItemId], references: [id], onDelete: Cascade)
  movements StockMovement[]

  @@unique([stockItemId, batchNumber, serialNumber])
  @@index([stockItemId])
  @@index([batchNumber])
  @@index([expiryDate])
  @@map("stock_batches")
}

model StockMovement {
  id            String       @id @default(uuid()) @db.Uuid
  stockItemId   String       @map("stock_item_id") @db.Uuid
  batchId       String?      @map("batch_id") @db.Uuid
  movementType  MovementType @map("movement_type")
  quantity      Decimal      @db.Decimal(10, 3)
  unitCost      Decimal?     @map("unit_cost") @db.Decimal(10, 2)
  referenceType String?      @map("reference_type") @db.VarChar(50)
  referenceId   String?      @map("reference_id") @db.Uuid
  notes         String?      @db.Text
  performedBy   String       @map("performed_by") @db.Uuid
  createdAt     DateTime     @default(now()) @map("created_at")

  stockItem StockItem  @relation(fields: [stockItemId], references: [id])
  batch     StockBatch? @relation(fields: [batchId], references: [id])
  performer User       @relation(fields: [performedBy], references: [id])

  @@index([stockItemId])
  @@index([movementType])
  @@index([referenceType, referenceId])
  @@index([createdAt])
  @@map("stock_movements")
}

model Supplier {
  id            String   @id @default(uuid()) @db.Uuid
  branchId      String   @map("branch_id") @db.Uuid
  code          String   @db.VarChar(20)
  name          String   @db.VarChar(255)
  contactPerson String?  @map("contact_person") @db.VarChar(255)
  email         String?  @db.VarChar(255)
  phone         String?  @db.VarChar(30)
  addressLine1  String?  @map("address_line1") @db.VarChar(255)
  addressLine2  String?  @map("address_line2") @db.VarChar(255)
  city          String?  @db.VarChar(100)
  state         String?  @db.VarChar(100)
  zipCode       String?  @map("zip_code") @db.VarChar(20)
  paymentTerms  String?  @map("payment_terms") @db.VarChar(100)
  leadTimeDays  Int?     @default(0) @map("lead_time_days")
  notes         String?  @db.Text
  isActive      Boolean  @default(true) @map("is_active")
  deletedAt     DateTime? @map("deleted_at")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  branch        Branch         @relation(fields: [branchId], references: [id])
  purchaseOrders PurchaseOrder[]

  @@unique([code, branchId])
  @@index([branchId])
  @@map("suppliers")
}

model PurchaseOrder {
  id            String   @id @default(uuid()) @db.Uuid
  branchId      String   @map("branch_id") @db.Uuid
  poNumber      String   @unique @map("po_number") @db.VarChar(30)
  supplierId    String   @map("supplier_id") @db.Uuid
  status        PoStatus @default(DRAFT)
  orderDate     DateTime @default(now()) @map("order_date")
  expectedDate  DateTime? @map("expected_date")
  receivedDate  DateTime? @map("received_date")
  subtotal      Decimal  @default(0) @db.Decimal(12, 2)
  taxTotal      Decimal  @default(0) @map("tax_total") @db.Decimal(12, 2)
  shippingTotal Decimal  @default(0) @map("shipping_total") @db.Decimal(12, 2)
  grandTotal    Decimal  @default(0) @map("grand_total") @db.Decimal(12, 2)
  notes         String?  @db.Text
  createdBy     String   @map("created_by") @db.Uuid
  approvedBy    String?  @map("approved_by") @db.Uuid
  deletedAt     DateTime? @map("deleted_at")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  branch    Branch       @relation(fields: [branchId], references: [id])
  supplier  Supplier     @relation(fields: [supplierId], references: [id])
  creator   User         @relation("POCreator", fields: [createdBy], references: [id])
  approver  User?        @relation("POApprover", fields: [approvedBy], references: [id])
  lineItems PoLineItem[]

  @@index([branchId])
  @@index([supplierId])
  @@index([status])
  @@index([orderDate])
  @@map("purchase_orders")
}

model PoLineItem {
  id              String   @id @default(uuid()) @db.Uuid
  purchaseOrderId String   @map("purchase_order_id") @db.Uuid
  stockItemId     String?  @map("stock_item_id") @db.Uuid
  lineNumber      Int      @map("line_number")
  partNumber      String   @map("part_number") @db.VarChar(100)
  description     String   @db.VarChar(500)
  quantityOrdered Decimal  @default(1) @map("quantity_ordered") @db.Decimal(10, 3)
  quantityReceived Decimal @default(0) @map("quantity_received") @db.Decimal(10, 3)
  unitPrice       Decimal  @default(0) @map("unit_price") @db.Decimal(10, 2)
  lineTotal       Decimal  @default(0) @map("line_total") @db.Decimal(12, 2)
  notes           String?  @db.Text

  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  stockItem     StockItem?   @relation(fields: [stockItemId], references: [id])

  @@unique([purchaseOrderId, lineNumber])
  @@index([purchaseOrderId])
  @@map("po_line_items")
}

model Invoice {
  id            String        @id @default(uuid()) @db.Uuid
  branchId      String        @map("branch_id") @db.Uuid
  invoiceNumber String        @unique @map("invoice_number") @db.VarChar(30)
  workOrderId   String        @map("work_order_id") @db.Uuid
  customerId    String        @map("customer_id") @db.Uuid
  status        InvoiceStatus @default(DRAFT)
  invoiceDate   DateTime      @default(now()) @map("invoice_date")
  dueDate       DateTime      @map("due_date")
  subtotal      Decimal       @default(0) @db.Decimal(12, 2)
  discountType  String?       @map("discount_type") @db.VarChar(10)
  discountValue Decimal       @default(0) @map("discount_value") @db.Decimal(12, 2)
  taxTotal      Decimal       @default(0) @map("tax_total") @db.Decimal(12, 2)
  total         Decimal       @default(0) @db.Decimal(12, 2)
  amountPaid    Decimal       @default(0) @map("amount_paid") @db.Decimal(12, 2)
  notes         String?       @db.Text
  pdfGenerated  Boolean       @default(false) @map("pdf_generated")
  pdfS3Key      String?       @map("pdf_s3_key") @db.VarChar(500)
  cancelledAt   DateTime?     @map("cancelled_at")
  deletedAt     DateTime?     @map("deleted_at")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  branch      Branch           @relation(fields: [branchId], references: [id])
  workOrder   WorkOrder        @relation(fields: [workOrderId], references: [id])
  customer    Customer         @relation(fields: [customerId], references: [id])
  lines       InvoiceLine[]
  taxLines    TaxLine[]
  creditNotes CreditNote[]
  allocations PaymentAllocation[]

  @@index([branchId])
  @@index([workOrderId])
  @@index([customerId])
  @@index([status])
  @@index([invoiceDate])
  @@map("invoices")
}

model InvoiceLine {
  id            String  @id @default(uuid()) @db.Uuid
  invoiceId     String  @map("invoice_id") @db.Uuid
  lineType      String  @map("line_type") @db.VarChar(20)
  description   String  @db.VarChar(500)
  quantity      Decimal @default(1) @db.Decimal(10, 3)
  unitPrice     Decimal @default(0) @map("unit_price") @db.Decimal(10, 2)
  discount      Decimal @default(0) @db.Decimal(10, 2)
  lineTotal     Decimal @default(0) @map("line_total") @db.Decimal(12, 2)
  referenceType String? @map("reference_type") @db.VarChar(50)
  referenceId   String? @map("reference_id") @db.Uuid
  sortOrder     Int     @default(0) @map("sort_order")
  createdAt     DateTime @default(now()) @map("created_at")

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@map("invoice_lines")
}

model TaxLine {
  id        String  @id @default(uuid()) @db.Uuid
  invoiceId String  @map("invoice_id") @db.Uuid
  taxName   String  @map("tax_name") @db.VarChar(100)
  taxRate   Decimal @map("tax_rate") @db.Decimal(5, 3)
  taxBase   Decimal @map("tax_base") @db.Decimal(12, 2)
  taxAmount Decimal @map("tax_amount") @db.Decimal(12, 2)
  isCompound Boolean @default(false) @map("is_compound")
  createdAt DateTime @default(now()) @map("created_at")

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@map("tax_lines")
}

model CreditNote {
  id           String   @id @default(uuid()) @db.Uuid
  invoiceId    String   @map("invoice_id") @db.Uuid
  creditNumber String   @unique @map("credit_number") @db.VarChar(30)
  reason       String   @db.VarChar(500)
  amount       Decimal  @db.Decimal(12, 2)
  createdBy    String   @map("created_by") @db.Uuid
  deletedAt    DateTime? @map("deleted_at")
  createdAt    DateTime @default(now()) @map("created_at")

  invoice Invoice @relation(fields: [invoiceId], references: [id])
  creator User    @relation(fields: [createdBy], references: [id])

  @@index([invoiceId])
  @@map("credit_notes")
}

model Payment {
  id              String        @id @default(uuid()) @db.Uuid
  branchId        String        @map("branch_id") @db.Uuid
  amount          Decimal       @db.Decimal(12, 2)
  paymentMethod   PaymentMethod @map("payment_method")
  referenceNumber String?       @map("reference_number") @db.VarChar(100)
  paidAt          DateTime      @default(now()) @map("paid_at")
  receivedBy      String        @map("received_by") @db.Uuid
  notes           String?       @db.Text
  deletedAt       DateTime?     @map("deleted_at")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  branch      Branch              @relation(fields: [branchId], references: [id])
  receiver    User                @relation("PaymentReceiver", fields: [receivedBy], references: [id])
  allocations PaymentAllocation[]

  @@index([branchId])
  @@index([paidAt])
  @@index([paymentMethod])
  @@map("payments")
}

model PaymentAllocation {
  id        String  @id @default(uuid()) @db.Uuid
  paymentId String  @map("payment_id") @db.Uuid
  invoiceId String  @map("invoice_id") @db.Uuid
  amount    Decimal @db.Decimal(12, 2)
  createdAt DateTime @default(now()) @map("created_at")

  payment Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  invoice Invoice @relation(fields: [invoiceId], references: [id])

  @@index([paymentId])
  @@index([invoiceId])
  @@map("payment_allocations")
}

model ChecklistTemplate {
  id          String   @id @default(uuid()) @db.Uuid
  branchId    String   @map("branch_id") @db.Uuid
  name        String   @db.VarChar(255)
  serviceType String?  @map("service_type") @db.VarChar(100)
  isActive    Boolean  @default(true) @map("is_active")
  deletedAt   DateTime? @map("deleted_at")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  branch   Branch          @relation(fields: [branchId], references: [id])
  items    ChecklistItem[]
  qcResults QcInspectionResult[]

  @@index([branchId])
  @@map("checklist_templates")
}

model ChecklistItem {
  id                   String  @id @default(uuid()) @db.Uuid
  checklistTemplateId  String  @map("checklist_template_id") @db.Uuid
  description          String  @db.VarChar(500)
  isRequired           Boolean @default(true) @map("is_required")
  sortOrder            Int     @default(0) @map("sort_order")
  createdAt            DateTime @default(now()) @map("created_at")

  template  ChecklistTemplate @relation(fields: [checklistTemplateId], references: [id], onDelete: Cascade)
  qcChecks  QcCheck[]

  @@index([checklistTemplateId])
  @@map("checklist_items")
}

model QcInspectionResult {
  id                  String   @id @default(uuid()) @db.Uuid
  workOrderId         String   @map("work_order_id") @db.Uuid
  branchId            String   @map("branch_id") @db.Uuid
  checklistTemplateId String   @map("checklist_template_id") @db.Uuid
  inspectorId         String   @map("inspector_id") @db.Uuid
  result              String   @db.VarChar(10)
  notes               String?  @db.Text
  inspectedAt         DateTime @default(now()) @map("inspected_at")
  deletedAt           DateTime? @map("deleted_at")
  createdAt           DateTime @default(now()) @map("created_at")

  workOrder WorkOrder        @relation(fields: [workOrderId], references: [id])
  branch    Branch           @relation(fields: [branchId], references: [id])
  template  ChecklistTemplate @relation(fields: [checklistTemplateId], references: [id])
  inspector User             @relation(fields: [inspectorId], references: [id])
  checks    QcCheck[]

  @@index([workOrderId])
  @@index([inspectorId])
  @@index([result])
  @@map("qc_inspection_results")
}

model QcCheck {
  id              String  @id @default(uuid()) @db.Uuid
  qcResultId      String  @map("qc_result_id") @db.Uuid
  checklistItemId String  @map("checklist_item_id") @db.Uuid
  passed          Boolean
  notes           String? @db.Text
  createdAt       DateTime @default(now()) @map("created_at")

  qcResult      QcInspectionResult @relation(fields: [qcResultId], references: [id], onDelete: Cascade)
  checklistItem ChecklistItem      @relation(fields: [checklistItemId], references: [id])

  @@index([qcResultId])
  @@map("qc_checks")
}

model Notification {
  id            String   @id @default(uuid()) @db.Uuid
  userId        String   @map("user_id") @db.Uuid
  type          String   @db.VarChar(50)
  title         String   @db.VarChar(255)
  body          String?  @db.Text
  data          Json?
  referenceType String?  @map("reference_type") @db.VarChar(50)
  referenceId   String?  @map("reference_id") @db.Uuid
  isRead        Boolean  @default(false) @map("is_read")
  readAt        DateTime? @map("read_at")
  createdAt     DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([userId, isRead])
  @@index([createdAt])
  @@map("notifications")
}

model Document {
  id          String   @id @default(uuid()) @db.Uuid
  branchId    String   @map("branch_id") @db.Uuid
  fileName    String   @map("file_name") @db.VarChar(255)
  originalName String  @map("original_name") @db.VarChar(255)
  mimeType    String   @map("mime_type") @db.VarChar(100)
  fileSize    Int      @map("file_size")
  s3Key       String   @map("s3_key") @db.VarChar(500)
  category    String?  @db.VarChar(50)
  entityType  String?  @map("entity_type") @db.VarChar(50)
  entityId    String?  @map("entity_id") @db.Uuid
  version     Int      @default(1)
  uploadedBy  String   @map("uploaded_by") @db.Uuid
  checksum    String?  @db.VarChar(64)
  deletedAt   DateTime? @map("deleted_at")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  branch   Branch @relation(fields: [branchId], references: [id])
  uploader User   @relation(fields: [uploadedBy], references: [id])

  @@index([branchId])
  @@index([entityType, entityId])
  @@index([category])
  @@map("documents")
}

model AuditEntry {
  id              String   @id @default(uuid()) @db.Uuid
  branchId        String?  @map("branch_id") @db.Uuid
  userId          String?  @map("user_id") @db.Uuid
  action          String   @db.VarChar(50)
  entityType      String   @map("entity_type") @db.VarChar(100)
  entityId        String   @map("entity_id") @db.Uuid
  entityLabel     String?  @map("entity_label") @db.VarChar(255)
  oldValues       Json?    @map("old_values")
  newValues       Json?    @map("new_values")
  changes         Json?
  ipAddress       String?  @map("ip_address") @db.VarChar(45)
  userAgent       String?  @map("user_agent") @db.Text
  checksum        String?  @db.VarChar(64)
  previousChecksum String? @map("previous_checksum") @db.VarChar(64)
  createdAt       DateTime @default(now()) @map("created_at")

  branch Branch? @relation(fields: [branchId], references: [id])
  user   User?   @relation(fields: [userId], references: [id])

  @@index([branchId])
  @@index([userId])
  @@index([entityType, entityId])
  @@index([action])
  @@index([createdAt])
  @@index([checksum])
  @@map("audit_entries")
}

model TransferOrder {
  id              String         @id @default(uuid()) @db.Uuid
  transferNumber  String         @unique @map("transfer_number") @db.VarChar(30)
  fromBranchId    String         @map("from_branch_id") @db.Uuid
  toBranchId      String         @map("to_branch_id") @db.Uuid
  status          TransferStatus @default(DRAFT)
  requestedBy     String         @map("requested_by") @db.Uuid
  approvedBy      String?        @map("approved_by") @db.Uuid
  shippedAt       DateTime?      @map("shipped_at")
  receivedAt      DateTime?      @map("received_at")
  notes           String?        @db.Text
  deletedAt       DateTime?      @map("deleted_at")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  fromBranch Branch              @relation("FromBranch", fields: [fromBranchId], references: [id])
  toBranch   Branch              @relation("ToBranch", fields: [toBranchId], references: [id])
  requester  User                @relation("TransferRequester", fields: [requestedBy], references: [id])
  approver   User?               @relation("TransferApprover", fields: [approvedBy], references: [id])
  items      TransferOrderItem[]

  @@index([fromBranchId])
  @@index([toBranchId])
  @@index([status])
  @@map("transfer_orders")
}

model TransferOrderItem {
  id                String  @id @default(uuid()) @db.Uuid
  transferOrderId   String  @map("transfer_order_id") @db.Uuid
  stockItemId       String  @map("stock_item_id") @db.Uuid
  quantity          Decimal @db.Decimal(10, 3)
  quantityReceived  Decimal @default(0) @map("quantity_received") @db.Decimal(10, 3)
  batchNumber       String? @map("batch_number") @db.VarChar(100)
  serialNumber      String? @map("serial_number") @db.VarChar(100)

  transferOrder TransferOrder @relation(fields: [transferOrderId], references: [id], onDelete: Cascade)
  stockItem     StockItem     @relation(fields: [stockItemId], references: [id])

  @@index([transferOrderId])
  @@index([stockItemId])
  @@map("transfer_order_items")
}
