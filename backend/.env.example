# Database
DATABASE_URL=postgresql://mechanica:mechanica_secret@localhost:5432/mechanica

# Redis
REDIS_URL=redis://:redis_secret@localhost:6379
REDIS_PREFIX=mechanica:dev:

# JWT
JWT_SECRET=dev-jwt-secret-change-in-production
JWT_REFRESH_SECRET=dev-refresh-secret-change-in-production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# AWS
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=mechanica-documents
S3_ENDPOINT=http://localhost:9000

# Email
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@mechanica.local

# Server
PORT=4000
NODE_ENV=development

# Rate Limiting
THROTTLE_TTL=60000
THROTTLE_LIMIT=60
AUTH_THROTTLE_LIMIT=10

# Features
ENABLE_AUDIT_HASH_CHAIN=true
AUDIT_RETENTION_DAYS=2555
