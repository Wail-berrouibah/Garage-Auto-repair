DATABASE_URL=postgresql://mechanica:mechanica_secret@localhost:5432/mechanica
REDIS_URL=redis://:redis_secret@localhost:6379
REDIS_PREFIX=mechanica:dev:
JWT_SECRET=dev-jwt-secret-change-in-production
JWT_REFRESH_SECRET=dev-refresh-secret-change-in-production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
AWS_REGION=us-east-1
S3_BUCKET=mechanica-documents
S3_ENDPOINT=http://localhost:9000
SMTP_HOST=localhost
SMTP_PORT=1025
EMAIL_FROM=noreply@mechanica.local
PORT=4000
NODE_ENV=development
THROTTLE_TTL=60000
THROTTLE_LIMIT=60
AUTH_THROTTLE_LIMIT=10
ENABLE_AUDIT_HASH_CHAIN=true
AUDIT_RETENTION_DAYS=2555

SHADOW_DATABASE_URL=postgresql://mechanica:mechanica_secret@localhost:5432/mechanica_shadow
